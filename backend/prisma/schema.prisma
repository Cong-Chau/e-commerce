generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────

enum AccountProvider {
  LOCAL
  GOOGLE
  FACEBOOK
}

enum RoleName {
  CUSTOMER
  SELLER
  ADMIN
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  COD
  BANK_TRANSFER
  MOMO
  VNPAY
  CREDIT_CARD
}

enum PaymentStatus {
  UNPAID
  PAID
  FAILED
  REFUNDED
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}

enum ShippingMethodName {
  FAST
  EXPRESS
  SAME_DAY
}

// ─── Models ─────────────────────────────────────────────────────

model User {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  phone      String?
  status     String   @default("ACTIVE")
  created_at DateTime @default(now())

  accounts      Account[]
  userRoles     UserRole[]
  cart          Cart?
  orders        Order[]
  reviews       Review[]
  chatbotLogs   ChatbotLog[]
  sellerProfile SellerProfile?

  // Conversations
  buyerConversations  Conversation[] @relation("BuyerConversations")
  sellerConversations Conversation[] @relation("SellerConversations")
  sentMessages        Message[]      @relation("SentMessages")

  // Products (nếu là Seller)
  products Product[]

  @@map("users")
}

model Account {
  id                       Int             @id @default(autoincrement())
  user_id                  Int
  username                 String?         @unique
  password                 String?
  provider                 AccountProvider @default(LOCAL)
  provider_id              String?
  is_verified              Boolean         @default(false)
  refresh_token            String?         @unique
  refresh_token_expires_at DateTime?
  created_at               DateTime        @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Role {
  id        Int        @id @default(autoincrement())
  name      RoleName   @unique

  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  user_id Int
  role_id Int

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role Role @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([user_id, role_id])
  @@map("user_roles")
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  parent_id Int?

  parent   Category?  @relation("CategoryChildren", fields: [parent_id], references: [id])
  children Category[] @relation("CategoryChildren")
  products Product[]

  @@map("categories")
}

model Product {
  id          Int           @id @default(autoincrement())
  name        String
  description String?
  price       Decimal       @db.Decimal(12, 2)
  stock       Int           @default(0)
  category_id Int
  seller_id   Int
  status      ProductStatus @default(ACTIVE)
  created_at  DateTime      @default(now())

  category   Category       @relation(fields: [category_id], references: [id])
  seller     User           @relation(fields: [seller_id], references: [id])
  images     ProductImage[]
  cartItems  CartItem[]
  orderItems OrderItem[]
  reviews    Review[]

  @@map("products")
}

model ProductImage {
  id         Int    @id @default(autoincrement())
  product_id Int
  image_url  String

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Cart {
  id      Int @id @default(autoincrement())
  user_id Int @unique

  user      User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  cartItems CartItem[]

  @@map("carts")
}

model CartItem {
  id         Int @id @default(autoincrement())
  cart_id    Int
  product_id Int
  quantity   Int

  cart    Cart    @relation(fields: [cart_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([cart_id, product_id])
  @@map("cart_items")
}

model Order {
  id               Int           @id @default(autoincrement())
  user_id          Int
  total_price      Decimal       @db.Decimal(12, 2)
  status           OrderStatus   @default(PENDING)
  shipping_address String
  payment_method   PaymentMethod @default(COD)
  payment_status   PaymentStatus @default(UNPAID)
  created_at       DateTime      @default(now())

  user       User        @relation(fields: [user_id], references: [id])
  orderItems OrderItem[]

  @@map("orders")
}

model OrderItem {
  id         Int     @id @default(autoincrement())
  order_id   Int
  product_id Int
  price      Decimal @db.Decimal(12, 2)
  quantity   Int

  order   Order   @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id])

  @@map("order_items")
}

model Conversation {
  id         Int      @id @default(autoincrement())
  buyer_id   Int
  seller_id  Int
  created_at DateTime @default(now())

  buyer    User      @relation("BuyerConversations", fields: [buyer_id], references: [id])
  seller   User      @relation("SellerConversations", fields: [seller_id], references: [id])
  messages Message[]

  @@unique([buyer_id, seller_id])
  @@map("conversations")
}

model Message {
  id              Int         @id @default(autoincrement())
  conversation_id Int
  sender_id       Int
  content         String
  message_type    MessageType @default(TEXT)
  is_read         Boolean     @default(false)
  created_at      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [sender_id], references: [id])

  @@map("messages")
}

model Review {
  id         Int      @id @default(autoincrement())
  user_id    Int
  product_id Int
  rating     Int      // 1–5
  comment    String?
  created_at DateTime @default(now())

  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([user_id, product_id])
  @@map("reviews")
}

model OtpCode {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  otp           String
  expired_at    DateTime
  attempt_count Int      @default(0)
  created_at    DateTime @default(now())

  @@map("otp_codes")
}

model ChatbotLog {
  id         Int      @id @default(autoincrement())
  user_id    Int
  question   String
  answer     String
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("chatbot_logs")
}

model SellerProfile {
  id               Int      @id @default(autoincrement())
  user_id          Int      @unique
  shop_name        String
  shop_logo        String?
  shop_description String?
  pickup_address   String?
  owner_name       String?
  owner_phone      String?
  created_at       DateTime @default(now())

  user            User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  sellerShippings SellerShipping[]

  @@map("seller_profiles")
}

model ShippingMethod {
  id   Int                @id @default(autoincrement())
  name ShippingMethodName @unique

  sellerShippings SellerShipping[]

  @@map("shipping_methods")
}

model SellerShipping {
  seller_id   Int
  shipping_id Int

  seller   SellerProfile  @relation(fields: [seller_id], references: [id], onDelete: Cascade)
  shipping ShippingMethod @relation(fields: [shipping_id], references: [id], onDelete: Cascade)

  @@id([seller_id, shipping_id])
  @@map("seller_shippings")
}
